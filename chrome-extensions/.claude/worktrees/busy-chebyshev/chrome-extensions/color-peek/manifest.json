{
  "manifest_version": 3,
  "name": "ColorPeek - Page Color Palette Extractor",
  "version": "1.0.0",
  "description": "Extract all colors used on any webpage. Get the full color palette with HEX, RGB, and HSL values. One-click copy.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ColorPeek",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
