{
  "manifest_version": 3,
  "name": "ResponsePeek - HTTP Header Viewer",
  "version": "1.0.0",
  "description": "Instantly view HTTP response headers, security headers, caching info, and server details for any page. Essential for web developers.",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ResponsePeek",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
