{
  "manifest_version": 3,
  "name": "QuickNote - Notes for Any Page",
  "version": "1.0.0",
  "description": "Take quick notes linked to any webpage. Your notes are automatically saved and restored when you revisit the page.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickNote",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
